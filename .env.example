# Printify — https://printify.com/app/account/api
# Generate a Personal Access Token with scopes:
#   shops.read products.read products.write uploads.read uploads.write
#   orders.read orders.write webhooks.read webhooks.write catalog.read
PRINTIFY_API_TOKEN=

# Required by Printify. Should identify the integration + contact email.
# Example: "lmao-merch/1.0 (contact@example.com)"
PRINTIFY_USER_AGENT=lmao-merch/1.0
